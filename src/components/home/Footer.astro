---
import { ArrowBigLeftDash, ArrowBigRightDash } from "@lucide/astro";
---

<div class="mx-auto mt-auto flex w-fit flex-col items-center gap-2 pb-5">
  <div class="flex w-full items-end justify-center gap-2">
    <a
      href="https://ring.liampas.ca/left"
      class="hover:text-foreground-alt duration-75 ease-linear select-none hover:scale-110 active:scale-97"
    >
      <ArrowBigLeftDash size={14} />
    </a>

    <h1 class="text-xs">Webring</h1>

    <a
      href="https://ring.liampas.ca/right"
      class="hover:text-foreground-alt duration-75 ease-linear select-none hover:scale-110 active:scale-97"
    >
      <ArrowBigRightDash size={14} />
    </a>
  </div>
  <h1 class="w-fit text-xs whitespace-nowrap">
    &copy; 2025 - 2026 Nikolaos Komninos
  </h1>
</div>
