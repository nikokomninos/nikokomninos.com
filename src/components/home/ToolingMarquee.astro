---
import {
  FaGolang,
  FaPython,
  FaReact,
  FaVuejs,
  FaNode,
  FaAws,
  FaDocker,
  FaJava,
  FaGithub,
} from "react-icons/fa6";
import { BiLogoTypescript } from "react-icons/bi";
import {
  SiExpress,
  SiNuxtdotjs,
  SiBun,
  SiRender,
  SiMongodb,
  SiPostgresql,
  SiC,
  SiCplusplus,
} from "react-icons/si";
import {
  RiNextjsLine,
  RiTailwindCssFill,
  RiSupabaseFill,
} from "react-icons/ri";
import { IoLogoVercel } from "react-icons/io5";

const tools = [
  { Icon: FaJava, name: "Java" },
  { Icon: FaGolang, name: "Go" },
  { Icon: SiC, name: "C" },
  { Icon: SiCplusplus, name: "C++" },
  { Icon: FaPython, name: "Python" },
  { Icon: BiLogoTypescript, name: "TypeScript" },
  { Icon: FaReact, name: "React" },
  { Icon: FaNode, name: "Node" },
  { Icon: SiExpress, name: "Express" },
  { Icon: RiNextjsLine, name: "Next" },
  { Icon: RiTailwindCssFill, name: "Tailwind" },
  { Icon: SiMongodb, name: "MongoDB" },
  { Icon: SiPostgresql, name: "PostgreSQL" },
  { Icon: RiSupabaseFill, name: "Supabase" },
  { Icon: FaAws, name: "AWS" },
  { Icon: FaDocker, name: "Docker" },
  { Icon: FaGithub, name: "Git" },
  { Icon: SiBun, name: "Bun" },
  { Icon: SiRender, name: "Render" },
  { Icon: IoLogoVercel, name: "Vercel" },
];

const allTools = [...tools, ...tools, ...tools];
---

<div
  id="marquee-container"
  class="border-foreground-alt/50 flex h-10 w-full items-center overflow-hidden rounded-md border"
>
  <div class="marquee-track flex items-center gap-8">
    {
      allTools.map(({ Icon, name }, _) => (
        <div class="hover:text-foreground-alt flex items-center gap-2 whitespace-nowrap duration-75 ease-linear select-none">
          <Icon className="text-xl" />
          <span class="text-sm">{name}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-33.33%);
    }
  }

  .marquee-track {
    animation: marquee 90s linear infinite;
  }

  #marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }
</style>
