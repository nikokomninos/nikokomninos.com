---
import "../styles/global.css";
import Navbar from "../components/nav/Navbar.astro";
import Footer from "../components/home/Footer.astro";

interface Props {
  hideNavbar?: boolean;
}

const { hideNavbar = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Niko Komninos</title>
    <meta property="og:title" content="Niko Komninos" />
    <meta property="og:image" content="https://nikokomninos.com/tool.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Niko Komninos" />
    <meta name="twitter:image" content="https://nikokomninos.com/tool.png" />
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const isDark = savedTheme === 'dark';
      if (isDark) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="px-5 md:px-0 mx-auto flex min-h-screen w-full md:w-1/2 lg:w-3/8 flex-col">
    {!hideNavbar && <Navbar />}
    <main
      class:list={[
        "bg-background w-full flex-1",
        hideNavbar && "flex flex-col",
      ]}
    >
      <slot />
    </main>
    <Footer />
  </body>
</html>
